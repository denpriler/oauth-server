{
    "preset": "psr12",
    "exclude": [
        "var",
        "vendor"
    ],
    "rules": {
        "no_extra_blank_lines": {
            "tokens": [
                "curly_brace_block",
                "extra",
                "parenthesis_brace_block",
                "square_brace_block",
                "throw",
                "use"
            ]
        }
    }
}
